# ========================================
# 🎓 AssignPortal - Environment Variables Template
# ========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ========================================

# 🟢 Supabase Configuration
VITE_SUPABASE_URL=your-project-url.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ========================================
# Supabase Service Role Key (ADMIN)
# ========================================
# WARNING: This key has FULL ADMIN access to your database!
#
# Powers/Abilities:
# - Bypass ALL Row Level Security (RLS) policies
# - Create, update, delete ANY user
# - Read/write to ANY table without restrictions
# - Manage storage buckets and files
# - Send emails on behalf of users
# - Create/delete auth users
#
# Security Notes:
# - NEVER expose this key to frontend/browser
# - NEVER commit to public repositories
# - Only use in backend servers, Edge Functions, or admin scripts
# - If leaked, immediately rotate in Supabase Dashboard
#
# Use Cases:
# - Creating users programmatically
# - Admin operations that bypass RLS
# - Backend API calls
# - Data migrations
#
# Get it from: Supabase Dashboard > Settings > API > service_role key
# ========================================
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# 📁 Storage Configuration (Supabase Bucket)
VITE_STORAGE_BUCKET=assignments

# ⚙️ App Settings
VITE_MAX_FILE_SIZE_MB=25
VITE_APP_MODE=supabase
